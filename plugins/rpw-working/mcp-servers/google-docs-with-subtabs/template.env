# Copy this file to dev.env, test.env, or prod.env and fill values.
# Select at runtime with APP_ENV=dev|test|prod.
# Google Docs MCP uses gcloud ADC (gcloud auth application-default login).

# Required: GCP quota project for API calls
GDOCS_QUOTA_PROJECT=your-gcp-project-id

# Required for list/create defaults
GDOCS_TARGET_FOLDER_ID=your_folder_id_here

# Optional: comma-separated folder IDs allowed for operations
# GDOCS_ALLOWED_FOLDERS=folder1,folder2,folder3

# Optional: read-only mode
# GDOCS_READ_ONLY=false

# Optional: path to append-only audit log
# GDOCS_AUDIT_LOG_PATH=/tmp/gdocs_mcp_audit.log
