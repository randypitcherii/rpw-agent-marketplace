# Google Docs MCP — Auth via gcloud ADC (gcloud auth application-default login)
# No OAuth credentials needed; uses Application Default Credentials.

# GCP quota project for API calls (required)
GDOCS_QUOTA_PROJECT=your-gcp-project-id

# Default target folder ID for create/list operations
GDOCS_TARGET_FOLDER_ID=your_folder_id_here

# Optional: comma-separated folder IDs allowed for operations (overrides single folder)
# GDOCS_ALLOWED_FOLDERS=folder1,folder2,folder3

# Optional: read-only mode — blocks create, update, delete, add_tab, find_replace, write_to_tab
# GDOCS_READ_ONLY=false

# Optional: path to audit log file (append-only; each mutation logs one line)
# GDOCS_AUDIT_LOG_PATH=/tmp/gdocs_mcp_audit.log
